<script setup>
import { ref, onMounted } from 'vue'

const APIData = ref([])
onMounted(async () => {
  const APIDataCall = await fetch('https://jsonplaceholder.typicode.com/users')
  APIData.value = await APIDataCall.json()
})

</script>

<template>

  <h1>API Data</h1>

  <div v-if="APIData.length">
    <h3>Data is here:</h3>
    <div v-for="APIDataItem in APIData" :key="APIDataItem.id">
    {{ APIDataItem.name }}
  </div>
  </div>
  <p v-else>Loading APIData...</p>

</template>
