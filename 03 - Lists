<script setup>
import { ref } from 'vue'

const show = ref(true)
const items = ref(['Apple', 'Banana', 'Cherry','Batata'])
</script>

<template>
  <button @click="show = !show">Toggle List</button>
  
  <div v-if="show">
    The list is visible.
  
  <br/>
  <h3>Bullet List</h3>
  <ul>
    <li v-for="item in items" :key="item">
      {{ item }}
    </li>
  </ul>


 
  <br/>
  <h3>Plain List</h3>
  <div v-for="value in items">
    {{value}}
  </div>
  
  </div>
</template>
